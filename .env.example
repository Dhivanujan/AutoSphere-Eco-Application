# Firebase Configuration
# Replace these values with your actual Firebase project web app configuration.
# Prefixing with EXPO_PUBLIC_ makes them available inside the React Native bundle.

EXPO_PUBLIC_FIREBASE_API_KEY=AIzaSy...
